{
  "expo": {
    "name": "Gym Form Coach",
    "slug": "gym-form-coach",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wkliwk.gymformcoach",
      "deploymentTarget": "14.0",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Gym Form Coach uses your camera to analyze exercise form in real time. All processing happens on your device."
      }
    },
    "android": {
      "package": "com.wkliwk.gymformcoach",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "gym-form-coach",
          "organization": "wkliwk"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Gym Form Coach uses your camera to analyze exercise form in real time. All processing happens on your device."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b85b8c36-fb16-4706-a01e-4c3ad1da28b3"
      }
    },
    "owner": "wkliwk"
  }
}
